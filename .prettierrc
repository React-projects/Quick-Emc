{
    "htmlWhitespaceSensitivity": "ignore",
    "singleAttributePerLine": false,
    "printWidth": 400,
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "arrowParens": "avoid",
    "bracketSpacing": true,
    "jsxBracketSameLine": false,
    "endOfLine": "auto",
    "vueIndentScriptAndStyle": true
}
